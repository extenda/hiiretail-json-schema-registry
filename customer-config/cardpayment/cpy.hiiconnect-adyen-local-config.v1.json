{
  "$id": "cpy.hiiconnect-adyen-local-config.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adyen TAPI local card payment configuration",
  "description": "Adyen TAPI local card payment configuration.",
  "type": "object",
  "required": [
    "environment",
    "encryptionKeyVersion",
    "encryptionKeyIdentifier",
    "encryptionKeyPassphrase",
    "receiptLineWidth",
    "webhookPort",
    "apiKey"
  ],
  "properties": {
    "environment": {
      "description": "Environment for the requests. Use 'SANDBOX' for testing with the thirdparty's test backend system, 'MOCK' for testing with Extenda Retail's simulator and 'PRODUCTION' for live transactions",
      "type": "string",
      "default": "PRODUCTION",
      "enum": [
        "MOCK",
        "PRODUCTION",
        "SANDBOX"
      ]
    },
    "encryptionKeyVersion": {
      "description": "Device encryption key version",
      "type": "string",
      "minLength": 1,
      "maxLength": 10,
      "default": "1",
      "example": "1"
    },
    "encryptionKeyIdentifier": {
      "description": "Device encryption key identifier",
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "example": "key-identifier"
    },
    "encryptionKeyPassphrase": {
      "description": "Device encryption key passphrase",
      "type": "string",
      "minLength": 12,
      "maxLength": 256,
      "example": "key-passphrase"
    },
    "receiptLineWidth": {
      "description": "Line width for the merchant and customer receipts",
      "type": "integer",
      "minLength": 1,
      "maxLength": 2,
      "default": 42,
      "example": "42"
    },
    "webhookPort": {
      "description": "Webhook port for receiving notifications",
      "type": "string",
      "minLength": 4,
      "maxLength": 4,
      "example": "8888"
    },
    "apiKey": {
      "description": "API Key for managing notifications setup",
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "example": "apiKey"
    }
  }
}
