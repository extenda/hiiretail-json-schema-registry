{
  "$id": "icd.settings.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Settings",
  "description": "Interactive Customer Display settings.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "layouts": {
      "description": "Widget layouts per display state.",
      "type": "object",
      "required": ["grid", "idle", "hasTransaction"],
      "additionalProperties": false,
      "properties": {
        "grid": {
          "description": "Grid dimensions shared across all display states.",
          "$ref": "#/$defs/GridType"
        },
        "idle": {
          "description": "Layout shown when the display is idle (no customer interaction).",
          "$ref": "#/$defs/IdleLayoutType"
        },
        "hasTransaction": {
          "description": "Layout shown during an active transaction.",
          "$ref": "#/$defs/HasTransactionLayoutType"
        },
        "noTransaction": {
          "description": "Layout shown when a customer is present but no transaction is active. Falls back to idle if not configured.",
          "$ref": "#/$defs/NoTransactionLayoutType"
        }
      }
    }
  },
  "$defs": {
    "GridType": {
      "description": "Grid dimensions defining the layout grid.",
      "type": "object",
      "required": ["columns", "rows"],
      "additionalProperties": false,
      "properties": {
        "columns": {
          "description": "Number of columns in the grid.",
          "type": "integer",
          "minimum": 1
        },
        "rows": {
          "description": "Number of rows in the grid.",
          "type": "integer",
          "minimum": 1
        },
        "gap": {
          "description": "Uniform gap between rows and columns in pixels. Overridden by rowGap/columnGap.",
          "type": "integer",
          "minimum": 0
        },
        "rowGap": {
          "description": "Gap between rows in pixels. Takes precedence over gap.",
          "type": "integer",
          "minimum": 0
        },
        "columnGap": {
          "description": "Gap between columns in pixels. Takes precedence over gap.",
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "PositionType": {
      "description": "Widget position and span within the grid (1-based indices).",
      "type": "object",
      "required": ["col", "row", "colSpan", "rowSpan"],
      "additionalProperties": false,
      "properties": {
        "col": {
          "description": "Column start position (1-based).",
          "type": "integer",
          "minimum": 1
        },
        "row": {
          "description": "Row start position (1-based).",
          "type": "integer",
          "minimum": 1
        },
        "colSpan": {
          "description": "Number of columns the widget spans.",
          "type": "integer",
          "minimum": 1
        },
        "rowSpan": {
          "description": "Number of rows the widget spans.",
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "WelcomeMessageWidgetType": {
      "description": "Displays a welcome message to the customer.",
      "type": "object",
      "required": ["position", "message"],
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/PositionType"
        },
        "message": {
          "description": "The welcome message text to display.",
          "type": "string"
        }
      }
    },
    "ReceiptWidgetType": {
      "description": "Displays the transaction receipt.",
      "type": "object",
      "required": ["position"],
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/PositionType"
        },
        "displayInvalidatedEntities": {
          "description": "Whether to display invalidated (voided/cancelled) entities on the receipt.",
          "type": "boolean"
        }
      }
    },
    "IdleLayoutType": {
      "description": "Layout for the idle state. Allowed widgets: welcomeMessage.",
      "type": "object",
      "required": ["widgets"],
      "additionalProperties": false,
      "properties": {
        "widgets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "welcomeMessage": {
              "$ref": "#/$defs/WelcomeMessageWidgetType"
            }
          }
        }
      }
    },
    "HasTransactionLayoutType": {
      "description": "Layout for the hasTransaction state. Allowed widgets: receipt.",
      "type": "object",
      "required": ["widgets"],
      "additionalProperties": false,
      "properties": {
        "widgets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "receipt": {
              "$ref": "#/$defs/ReceiptWidgetType"
            }
          }
        }
      }
    },
    "NoTransactionLayoutType": {
      "description": "Layout for the noTransaction state. Allowed widgets: welcomeMessage.",
      "type": "object",
      "required": ["widgets"],
      "additionalProperties": false,
      "properties": {
        "widgets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "welcomeMessage": {
              "$ref": "#/$defs/WelcomeMessageWidgetType"
            }
          }
        }
      }
    }
  }
}
