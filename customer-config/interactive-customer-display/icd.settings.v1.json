{
  "$id": "icd.settings.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Settings",
  "description": "Interactive Customer Display settings.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "layouts": {
      "description": "Widget layouts per display state.",
      "type": "object",
      "required": ["idle", "midOrder"],
      "additionalProperties": false,
      "properties": {
        "grid": {
          "description": "Grid dimensions shared across all display states.",
          "$ref": "#/$defs/GridType",
          "default": {
            "columns": 12,
            "rows": 12
          }
        },
        "idle": {
          "description": "Layout shown when the display is idle (no customer interaction).",
          "$ref": "#/$defs/IdleLayoutType"
        },
        "midOrder": {
          "description": "Layout shown during an active transaction.",
          "$ref": "#/$defs/MidOrderLayoutType"
        }
      }
    }
  },
  "$defs": {
    "GridType": {
      "description": "Grid dimensions defining the layout grid.",
      "type": "object",
      "required": ["columns", "rows"],
      "additionalProperties": false,
      "properties": {
        "columns": {
          "description": "Number of columns in the grid.",
          "type": "integer",
          "minimum": 1
        },
        "rows": {
          "description": "Number of rows in the grid.",
          "type": "integer",
          "minimum": 1
        },
        "gap": {
          "description": "Uniform gap between rows and columns in pixels. Overridden by rowGap/columnGap.",
          "type": "integer",
          "minimum": 0
        },
        "rowGap": {
          "description": "Gap between rows in pixels. Takes precedence over gap.",
          "type": "integer",
          "minimum": 0
        },
        "columnGap": {
          "description": "Gap between columns in pixels. Takes precedence over gap.",
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "PositionType": {
      "description": "Widget position and span within the grid (1-based indices).",
      "type": "object",
      "required": ["col", "row", "colSpan", "rowSpan"],
      "additionalProperties": false,
      "properties": {
        "col": {
          "description": "Column start position (1-based).",
          "type": "integer",
          "minimum": 1
        },
        "row": {
          "description": "Row start position (1-based).",
          "type": "integer",
          "minimum": 1
        },
        "colSpan": {
          "description": "Number of columns the widget spans.",
          "type": "integer",
          "minimum": 1
        },
        "rowSpan": {
          "description": "Number of rows the widget spans.",
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "WelcomeMessageWidgetType": {
      "description": "Displays a welcome message to the customer.",
      "type": "object",
      "required": ["position", "message"],
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/PositionType"
        },
        "message": {
          "description": "The welcome message text to display.",
          "type": "string"
        }
      }
    },
    "ReceiptWidgetType": {
      "description": "Displays the transaction receipt.",
      "type": "object",
      "required": ["position"],
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/PositionType"
        },
        "displayInvalidatedEntities": {
          "description": "Whether to display invalidated (voided/cancelled) entities on the receipt.",
          "type": "boolean"
        }
      }
    },
    "ImageSourceType": {
      "description": "A single image source entry.",
      "type": "object",
      "required": ["id", "active"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "description": "Image URL, will act as an identifier.",
          "type": "string",
          "format": "uri"
        },
        "active": {
          "description": "Whether this image is included in the rotation.",
          "type": "boolean"
        }
      }
    },
    "ImageWidgetType": {
      "description": "Rotates through a set of images",
      "type": "object",
      "required": ["position", "sources"],
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/PositionType"
        },
        "sources": {
          "description": "List of image sources. Only entries with active: true are displayed.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ImageSourceType"
          },
          "minItems": 1
        },
        "interval": {
          "description": "Rotation interval in milliseconds. Only used with multiple active sources.",
          "type": "integer",
          "minimum": 1000,
          "default": 5000
        }
      }
    },
    "VideoWidgetType": {
      "description": "Plays a video on loop (muted, auto-play).",
      "type": "object",
      "required": ["position", "src"],
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/PositionType"
        },
        "src": {
          "description": "Video URL.",
          "type": "string",
          "format": "uri"
        }
      }
    },
    "IdleLayoutType": {
      "description": "Layout for the idle state. Allowed widgets: welcomeMessage, image, video.",
      "type": "object",
      "required": ["widgets"],
      "additionalProperties": false,
      "properties": {
        "widgets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "welcomeMessage": {
              "$ref": "#/$defs/WelcomeMessageWidgetType"
            },
            "image": {
              "$ref": "#/$defs/ImageWidgetType"
            },
            "video": {
              "$ref": "#/$defs/VideoWidgetType"
            }
          }
        }
      }
    },
    "MidOrderLayoutType": {
      "description": "Layout for the midOrder state. Allowed widgets: receipt (required), image, video.",
      "type": "object",
      "required": ["widgets"],
      "additionalProperties": false,
      "properties": {
        "widgets": {
          "type": "object",
          "required": ["receipt"],
          "additionalProperties": false,
          "properties": {
            "receipt": {
              "$ref": "#/$defs/ReceiptWidgetType"
            },
            "image": {
              "$ref": "#/$defs/ImageWidgetType"
            },
            "video": {
              "$ref": "#/$defs/VideoWidgetType"
            }
          }
        }
      }
    }
  }
}
